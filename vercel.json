{
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://tradenet.mintlify.dev/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://tradenet.mintlify.dev/docs/:match*"
    },
    {
      "source": "/blog",
      "destination": "https://tradenet.mintlify.dev/blog"
    },
    {
      "source": "/blog/:match*",
      "destination": "https://tradenet.mintlify.dev/blog/:match*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
